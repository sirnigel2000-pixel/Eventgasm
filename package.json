{
  "name": "eventgasm",
  "version": "1.0.0",
  "description": "Nationwide event aggregation service",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "sync": "node -e \"require('./src/services/syncManager').runFullSync()\"",
    "sync:quick": "node -e \"require('./src/services/syncManager').runQuickSync()\""
  },
  "keywords": [
    "events",
    "aggregator",
    "concerts",
    "festivals",
    "sports"
  ],
  "author": "Sons of Beaches",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "node-cron": "^3.0.3",
    "pg": "^8.14.1",
    "sequelize": "^6.37.8",
    "uuid": "^11.1.0"
  }
}
